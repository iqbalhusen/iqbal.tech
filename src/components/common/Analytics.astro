---
import { ANALYTICS } from 'astrowind:config';

const id = ANALYTICS?.vendors?.googleAnalytics?.id ? String(ANALYTICS.vendors.googleAnalytics.id) : null;
---

{
  id ? (
    <>
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${id}`}></script>
      <script is:inline set:html={`
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
      
          gtag('config', '${id}');
        `}></script>
    </>
  ) : null
}
