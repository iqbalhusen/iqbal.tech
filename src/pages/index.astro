---
import Layout from '~/layouts/PageLayout.astro';

import Header from '~/components/widgets/Header.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Steps from '~/components/widgets/Steps.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Personal Homepage Demo',
};
---

<Layout metadata={metadata}>
  <Fragment slot="announcement"></Fragment>
  <Fragment slot="header">
    <Header
      links={[
        { text: 'Home', href: '#' },
        { text: 'About', href: '#about' },
        { text: 'Experience', href: '#resume' },
        { text: 'Projects', href: '#porfolio' }
      ]}
      isSticky
      showToggleTheme
    />
  </Fragment>

  <!-- Hero2 Widget ******************* -->

  <Hero
    id="hero"
    title="Iqbal Hussain"
    tagline="Senior Full-stack Developer"
    actions={[{ variant: 'primary', text: 'View resume', href: '/resume.pdf', target: '_blank' }]}
  >
    <Fragment slot="subtitle">
      I'm a full stack developer specializing in backend architecture, with over a decade of experience building, 
      scaling, and optimizing production platforms.
    </Fragment>
  </Hero>

  <!-- Content Widget **************** -->

  <Content
    id="about"
    columns={3}
    items={[
      {
        icon: 'tabler:brand-linkedin',
        callToAction: {
          target: '_blank',
          text: 'LinkedIn',
          href: '#',
        },
      },
      {
        icon: 'tabler:letter-t',
        callToAction: {
          target: '_blank',
          text: 'Toptal',
          href: '#',
        },
      },
      {
        icon: 'tabler:mail',
        callToAction: {
          target: '_blank',
          text: 'me@iqbal.tech',
          href: '#',
        },
      },
    ]}
    image={{
      src: '~/assets/images/profile-photos.png',
      alt: 'Colorful Image',
      loading: 'eager',
    }}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">About me</h2>
      <p>
        I am a senior full-stack developer specializing in Python and Django. My work centers on automating workflows 
        and building reliable systems that make data highly available and useful. I find satisfaction in writing code 
        that makes people's lives easier.
      </p>
      <br />
      <p>
        I have always been fascinated by how things work at a fundamental level. Outside of engineering, I lean into my 
        artistic side by taking photographs and spending quiet nights gazing sky.
      </p>
      <br />
      <p>If you want to connect with me:</p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <Features3
    title="Technical skills"
    subtitle="Core technologies and frameworks I use to build and scale production applications."
    columns={2}
    defaultIcon="tabler:point-filled"
    items={[
      {
        title: 'Languages',
        description: 'Python, JavaScript, Dart, Java, Bash',
      },
      {
        title: 'Cloud & DevOps ',
        description: 'AWS, GCP, Kubernetes, Docker, Jenkins, Nginx',
      },
      {
        title: 'Backend',
        description: 'Django, Django REST Framework, Celery, Elasticsearch, Pandas',
      },
      {
        title: 'Databases',
        description: 'PostgreSQL, MongoDB, Redis, Memcached, RabbitMQ',
      },
      {
        title: 'Frontend',
        description: 'React.js, Next.js, React Native, Flutter, Astro',
      },
      {
        title: 'Tools',
        description: 'Git, Selenium, Puppeteer, WebSockets, Payment Gateways',
      }
    ]}
  />
  
  <Steps
    id="resume"
    title="Work experience"
    bg='<div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>'
    items={[
      {
        title:
          'Founding Engineer & Technical Lead (Remote) <br /> <span class="font-normal">WORK JAPAN, Tokyo, Japan</span> <br /> <span class="text-sm font-normal">2018 - Present</span>',
        description: `• Directed technical strategy and designed core software architecture. <br /> • Engineered scalable frontend and backend systems. <br /> • Managed production infrastructure and application deployments on AWS. <br /> • Mentored the technical team to achieve engineering goals.`,
        icon: 'tabler:briefcase',
      },
      {
        title:
          'Full-Stack Engineer <br /> <span class="font-normal">Edelweiss Broking Ltd., Bengaluru, India</span> <br /> <span class="text-sm font-normal">2016 - 2018</span>',
        description: `• Led backend migration for a 50,000-user platform acquisition. <br /> • Engineered multithreaded Python pipelines for live market data. <br /> • Developed real-time WebSocket tools for server performance monitoring. <br /> • Designed enterprise Java REST APIs for financial services.`,
        icon: 'tabler:briefcase',
      },
      {
        title:
          'Backend Developer <br /> <span class="font-normal">WealthPack, Gurugram, India</span> <br /> <span class="text-sm font-normal">2015 - 2016</span>',
        description: `• Architected the foundational Python backend from scratch. <br /> • Built secure REST APIs for the primary mobile application. <br /> • Engineered automated website crawling and data extraction pipelines. <br /> • Deployed initial AWS infrastructure and background task processing.`,
        icon: 'tabler:briefcase',
      },







      {
        title:
          'Backend Developer <br /> <span class="font-normal">Empower Futures, Ahmedabad, India</span> <br /> <span class="text-sm font-normal">2014 - 2015</span>',
        description: `• Built core RESTful APIs using Python and Django. <br /> • Implemented secure authentication and managed PostgreSQL databases. <br /> • Integrated third-party APIs including Firebase and Google Maps. <br /> • Engineered Python ETL scripts for bulk data ingestion.`,
        icon: 'tabler:briefcase',
      },
    ]}
    classes={{ container: 'max-w-3xl' }}
  />

  <!-- Steps Widget ****************** -->

  <Steps
    id="resume"
    title="Education"
    items={[
      {
        title: `Master of Technology in Computer Science <br /> <span class="font-normal">CVR College of Engineering, Hyderabad</span> <br /> <span class="text-sm font-normal">2012 - 2014</span>`,
        icon: 'tabler:school',
      },
      {
        title: `Bachelor of Technology in Computer Science <br /> <span class="font-normal">Jawaharlal Nehru Technological University, Hyderabad</span> <br /> <span class="text-sm font-normal">2008 - 2012</span>`,
        icon: 'tabler:school',
      },
    ]}
    classes={{ container: 'max-w-3xl' }}
  />

  <!-- Content Widget **************** -->

  <Content
    id="porfolio"
    title="Featured projects"
    isReversed
    items={[
      {
        title: 'Description:',
        description:
          "Solving India's unstructured addressing for e-commerce logistics and everyday users. The platform eliminates delivery losses via a B2B merchant widget, while a consumer mobile app allows users to seamlessly manage and share exact locations.",
      },
      {
        title: 'Role:',
        description:
          'Architected the Python/Django backend and built a proprietary reverse-geocoding engine to bypass expensive APIs. Engineered the full ecosystem, including a React checkout widget, a Next.js merchant dashboard, and a Flutter-based consumer app.',
      },
    ]}
    image={{
      src: '~/assets/images/geophrase.png',
      alt: 'Tech Design Image',
    }}
    callToAction={{
      target: '_blank',
      text: 'Go to the project',
      icon: 'tabler:chevron-right',
      href: '#',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Geophrase: <br /><span class="text-2xl">Universal smart-address platform</span>
      </h3>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- CallToAction Widget *********** -->

  <CallToAction
    title="Let’s build together"
    subtitle="Looking to build a new system or improve an existing one?"
    actions={[
      {
        variant: 'primary',
        text: 'Get in touch',
        href: '/',
      },
    ]}
  />
</Layout>
